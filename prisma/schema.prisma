// Asset Management System - Database Schema
// SQL Server 2025 Standard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// ============================================================
// Organization Structure
// ============================================================

model Company {
  id           String   @id @default(uuid())
  code         String   @unique @db.NVarChar(20)
  assetTagCode String?  @db.NVarChar(20)
  nameTh       String   @db.NVarChar(200)
  nameEn       String?  @db.NVarChar(200)
  taxId        String?  @db.NVarChar(20)
  address      String?  @db.NVarChar(500)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?  @db.NVarChar(100)
  updatedBy    String?  @db.NVarChar(100)

  branches    Branch[]
  departments Department[]
  employees   Employee[]
  assets      Asset[]
  auditRounds AuditRound[]

  @@map("companies")
}

model Branch {
  id            String   @id @default(uuid())
  code          String   @db.NVarChar(20)
  name          String   @db.NVarChar(200)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address       String?  @db.NVarChar(500)
  contactPerson String?  @db.NVarChar(200)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?  @db.NVarChar(100)
  updatedBy     String?  @db.NVarChar(100)

  locations   Location[]
  employees   Employee[]
  assets      Asset[]
  auditRounds AuditRound[]

  @@unique([companyId, code])
  @@map("branches")
}

model Department {
  id        String   @id @default(uuid())
  code      String   @unique @db.NVarChar(20)
  name      String   @db.NVarChar(200)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.NVarChar(100)
  updatedBy String?  @db.NVarChar(100)

  employees   Employee[]
  assets      Asset[]
  auditRounds AuditRound[]

  @@map("departments")
}

model Employee {
  id               String     @id @default(uuid())
  code             String     @unique @db.NVarChar(20)
  fullNameTh       String     @db.NVarChar(200)
  fullNameEn       String?    @db.NVarChar(200)
  email            String?    @db.NVarChar(200)
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId         String
  branch           Branch     @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  position         String?    @db.NVarChar(200)
  employmentStatus String     @default("active") @db.NVarChar(20) // active, resigned, suspended
  managerId        String?
  manager          Employee?  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates     Employee[] @relation("EmployeeManager")
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  createdBy        String?    @db.NVarChar(100)
  updatedBy        String?    @db.NVarChar(100)

  custodianAssets             Asset[]             @relation("AssetCustodian")
  checkouts                   AssetCheckout[]     @relation("CheckoutCustodian")
  checkinReturns              AssetCheckin[]      @relation("CheckinReturnByEmployee")
  checkinReceives             AssetCheckin[]      @relation("CheckinReceiveByEmployee")
  reportedMaintenanceTickets  MaintenanceTicket[] @relation("MaintenanceReportedBy")
  assignedMaintenanceTickets  MaintenanceTicket[] @relation("MaintenanceAssignedTo")
  inspectedMaintenanceTickets MaintenanceTicket[] @relation("MaintenanceInspectedBy")
  assignedMaintenancePlans    MaintenancePlan[]   @relation("MaintenancePlanAssignedTo")
  assignedAuditFindings       AuditFinding[]      @relation("AuditFindingActionOwner")
  requestedDisposals          DisposalRequest[]   @relation("DisposalRequestedBy")
  approvedDisposals           DisposalRequest[]   @relation("DisposalApprover")
  executedDisposals           DisposalRequest[]   @relation("DisposalExecutedBy")
  user                        User?
  auditRounds                 AuditRound[]

  @@index([isActive, companyId, branchId], map: "IX_employees_isActive_companyId_branchId")
  @@index([departmentId], map: "IX_employees_departmentId")
  @@index([managerId], map: "IX_employees_managerId")
  @@map("employees")
}

// ============================================================
// Physical Location
// ============================================================

model Location {
  id           String     @id @default(uuid())
  code         String     @unique @db.NVarChar(50)
  name         String     @db.NVarChar(200)
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId     String?
  parent       Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Location[] @relation("LocationHierarchy")
  locationType String     @db.NVarChar(50) // Site, Building, Floor, Room, Area, Zone, Rack, etc.
  description  String?    @db.NVarChar(500)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?    @db.NVarChar(100)
  updatedBy    String?    @db.NVarChar(100)

  homeAssets    Asset[]      @relation("AssetHomeLocation")
  currentAssets Asset[]      @relation("AssetCurrentLocation")
  auditRounds   AuditRound[]

  @@index([isActive, branchId], map: "IX_locations_isActive_branchId")
  @@index([parentId], map: "IX_locations_parentId")
  @@map("locations")
}

// ============================================================
// Asset Classification
// ============================================================

model AssetCategory {
  id          String   @id @default(uuid())
  code        String   @unique @db.NVarChar(20)
  name        String   @db.NVarChar(200)
  description String?  @db.NVarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.NVarChar(100)
  updatedBy   String?  @db.NVarChar(100)

  models          AssetModel[]
  assets          Asset[]
  customFieldDefs CustomFieldDefinition[]
  auditRounds     AuditRound[]

  @@map("asset_categories")
}

model AssetBrand {
  id        String   @id @default(uuid())
  name      String   @unique @db.NVarChar(200)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models AssetModel[]
  assets Asset[]

  @@map("asset_brands")
}

model AssetModel {
  id         String        @id @default(uuid())
  name       String        @db.NVarChar(200)
  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brandId    String
  brand      AssetBrand    @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  specs      String?       @db.NVarChar(Max)
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  assets Asset[]

  @@unique([brandId, name])
  @@map("asset_models")
}

// ============================================================
// Asset Status & Condition (Reference Data)
// ============================================================

model AssetStatus {
  id          String  @id @default(uuid())
  name        String  @unique @db.NVarChar(50)
  nameTh      String  @db.NVarChar(100)
  description String? @db.NVarChar(200)
  colorCode   String? @db.NVarChar(20)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  assets      Asset[]
  auditRounds AuditRound[]

  @@map("asset_statuses")
}

model AssetCondition {
  id          String  @id @default(uuid())
  name        String  @unique @db.NVarChar(50)
  nameTh      String  @db.NVarChar(100)
  description String? @db.NVarChar(200)
  colorCode   String? @db.NVarChar(20)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  assets      Asset[]
  auditRounds AuditRound[]

  @@map("asset_conditions")
}

// ============================================================
// Asset Register
// ============================================================

model Asset {
  id                     String         @id @default(uuid())
  assetTag               String         @unique @db.NVarChar(50)
  name                   String         @db.NVarChar(200)
  categoryId             String
  category               AssetCategory  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brandId                String?
  brand                  AssetBrand?    @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  modelId                String?
  model                  AssetModel?    @relation(fields: [modelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  serialNumber           String?        @db.NVarChar(100)
  licenseTotalSeats      Int?
  licenseUsedSeats       Int?
  licenseAssignedAssetId String?
  licenseAssignedAsset   Asset?         @relation("LicenseAssignedAsset", fields: [licenseAssignedAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedLicenses       Asset[]        @relation("LicenseAssignedAsset")
  companyId              String
  company                Company        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId               String
  branch                 Branch         @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownershipType          String         @default("personal") @db.NVarChar(30)
  departmentId           String?
  department             Department?    @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  custodianId            String?
  custodian              Employee?      @relation("AssetCustodian", fields: [custodianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  homeLocationId         String?
  homeLocation           Location?      @relation("AssetHomeLocation", fields: [homeLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  currentLocationId      String
  currentLocation        Location       @relation("AssetCurrentLocation", fields: [currentLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  statusId               String
  status                 AssetStatus    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conditionId            String
  condition              AssetCondition @relation(fields: [conditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchaseDate           DateTime?
  purchasePrice          Decimal?       @db.Decimal(18, 2)
  supplierId             String?
  supplier               Supplier?      @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warrantyStartDate      DateTime?
  warrantyEndDate        DateTime?
  fixedAssetCode         String?        @db.NVarChar(50)
  poNumber               String?        @db.NVarChar(50)
  invoiceNumber          String?        @db.NVarChar(50)
  remark                 String?        @db.NVarChar(Max)
  customFieldsJson       String?        @db.NVarChar(Max) // JSON snapshot of custom fields
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  createdBy              String?        @db.NVarChar(100)
  updatedBy              String?        @db.NVarChar(100)

  customFieldValues     CustomFieldValue[]
  movements             AssetMovement[]
  checkouts             AssetCheckout[]
  checkins              AssetCheckin[]
  maintenancePlans      MaintenancePlan[]
  maintenanceTickets    MaintenanceTicket[]
  disposalRequests      DisposalRequest[]
  attachments           Attachment[]
  parentComponents      AssetComponent[]        @relation("ParentAssetComponents")
  installedInLinks      AssetComponent[]        @relation("ComponentAssetLinks")
  purchaseDocumentLinks PurchaseDocumentAsset[]
  auditItems            AuditItem[]
  auditFindings         AuditFinding[]
  auditScanHistory      AuditScanHistory[]
  labelPrints           AssetLabelPrint[]

  @@index([licenseAssignedAssetId])
  @@index([isActive, createdAt], map: "IX_assets_isActive_createdAt")
  @@index([isActive, companyId, branchId], map: "IX_assets_isActive_companyId_branchId")
  @@index([isActive, categoryId, modelId], map: "IX_assets_isActive_categoryId_modelId")
  @@index([isActive, brandId], map: "IX_assets_isActive_brandId")
  @@index([isActive, statusId, conditionId], map: "IX_assets_isActive_statusId_conditionId")
  @@index([isActive, ownershipType], map: "IX_assets_isActive_ownershipType")
  @@index([isActive, custodianId], map: "IX_assets_isActive_custodianId")
  @@index([isActive, currentLocationId], map: "IX_assets_isActive_currentLocationId")
  @@index([departmentId], map: "IX_assets_departmentId")
  @@index([supplierId], map: "IX_assets_supplierId")
  @@index([purchaseDate], map: "IX_assets_purchaseDate")
  @@index([warrantyEndDate], map: "IX_assets_warrantyEndDate")
  @@index([serialNumber], map: "IX_assets_serialNumber")
  @@map("assets")
}

model AssetLabelPrintBatch {
  id         String   @id @default(uuid())
  tapeSize   String   @db.NVarChar(20)
  assetCount Int
  reason     String?  @db.NVarChar(500)
  printedBy  String   @db.NVarChar(100)
  printedAt  DateTime @default(now())
  userAgent  String?  @db.NVarChar(500)

  items AssetLabelPrint[]

  @@index([printedAt])
  @@index([printedBy])
  @@map("asset_label_print_batches")
}

model AssetLabelPrint {
  id        String               @id @default(uuid())
  batchId   String
  batch     AssetLabelPrintBatch @relation(fields: [batchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetId   String
  asset     Asset                @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetTag  String               @db.NVarChar(50)
  tapeSize  String               @db.NVarChar(20)
  reason    String?              @db.NVarChar(500)
  printedBy String               @db.NVarChar(100)
  printedAt DateTime             @default(now())

  @@index([assetId, printedAt])
  @@index([batchId])
  @@map("asset_label_prints")
}

model AssetComponent {
  id               String    @id @default(uuid())
  parentAssetId    String
  parentAsset      Asset     @relation("ParentAssetComponents", fields: [parentAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  componentAssetId String
  componentAsset   Asset     @relation("ComponentAssetLinks", fields: [componentAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  componentRole    String    @db.NVarChar(100)
  slotNo           String?   @db.NVarChar(50)
  installedAt      DateTime  @default(now())
  removedAt        DateTime?
  status           String    @default("installed") @db.NVarChar(20)
  reason           String?   @db.NVarChar(500)
  referenceType    String?   @db.NVarChar(50)
  referenceId      String?   @db.NVarChar(100)
  createdBy        String?   @db.NVarChar(100)
  updatedBy        String?   @db.NVarChar(100)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([parentAssetId, status])
  @@index([componentAssetId, status])
  @@map("asset_components")
}

model PurchaseDocument {
  id            String    @id @default(uuid())
  documentType  String    @db.NVarChar(50)
  documentNo    String    @db.NVarChar(100)
  poNumber      String?   @db.NVarChar(100)
  invoiceNumber String?   @db.NVarChar(100)
  documentDate  DateTime?
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  totalAmount   Decimal?  @db.Decimal(18, 2)
  currency      String?   @db.NVarChar(10)
  remark        String?   @db.NVarChar(Max)
  isActive      Boolean   @default(true)
  createdBy     String?   @db.NVarChar(100)
  updatedBy     String?   @db.NVarChar(100)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assetLinks PurchaseDocumentAsset[]

  @@unique([documentType, documentNo])
  @@index([poNumber])
  @@index([invoiceNumber])
  @@index([supplierId])
  @@map("purchase_documents")
}

model PurchaseDocumentAsset {
  id                 String           @id @default(uuid())
  purchaseDocumentId String
  purchaseDocument   PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedAt           DateTime         @default(now())
  linkedBy           String?          @db.NVarChar(100)
  remark             String?          @db.NVarChar(500)

  @@unique([purchaseDocumentId, assetId])
  @@index([assetId])
  @@map("purchase_document_assets")
}

// ============================================================
// Custom Fields (EAV Pattern)
// ============================================================

model CustomFieldDefinition {
  id           String        @id @default(uuid())
  categoryId   String
  category     AssetCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fieldName    String        @db.NVarChar(100)
  fieldLabel   String        @db.NVarChar(200)
  fieldLabelTh String?       @db.NVarChar(200)
  fieldType    String        @db.NVarChar(20) // text, number, date, select, boolean
  options      String?       @db.NVarChar(Max) // JSON array for select type
  isRequired   Boolean       @default(false)
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)

  values CustomFieldValue[]

  @@unique([categoryId, fieldName])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id           String                @id @default(uuid())
  assetId      String
  asset        Asset                 @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  value        String?               @db.NVarChar(Max)

  @@unique([assetId, definitionId])
  @@map("custom_field_values")
}

// ============================================================
// Asset Transactions
// ============================================================

model AssetCheckout {
  id                 String    @id @default(uuid())
  documentNo         String?   @db.NVarChar(50)
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkoutType       String    @db.NVarChar(20) // user, department, location, asset
  custodianId        String?
  custodian          Employee? @relation("CheckoutCustodian", fields: [custodianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departmentId       String?   @db.NVarChar(100)
  locationId         String?   @db.NVarChar(100)
  parentAssetId      String?   @db.NVarChar(100)
  checkoutDate       DateTime
  expectedReturnDate DateTime?
  conditionBefore    String    @db.NVarChar(50)
  photoBefore        String?   @db.NVarChar(500)
  remark             String?   @db.NVarChar(Max)
  checkedOutBy       String    @db.NVarChar(100)
  receiverSignature  String?   @db.NVarChar(500)
  isReturned         Boolean   @default(false)
  createdAt          DateTime  @default(now())

  checkin AssetCheckin?

  @@index([documentNo])
  @@map("asset_checkouts")
}

model AssetCheckin {
  id                  String        @id @default(uuid())
  documentNo          String?       @db.NVarChar(50)
  assetId             String
  asset               Asset         @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkoutId          String        @unique
  checkout            AssetCheckout @relation(fields: [checkoutId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnDate          DateTime
  returnByEmployeeId  String?
  returnByEmployee    Employee?     @relation("CheckinReturnByEmployee", fields: [returnByEmployeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnBy            String        @db.NVarChar(100)
  receiveByEmployeeId String?
  receiveByEmployee   Employee?     @relation("CheckinReceiveByEmployee", fields: [receiveByEmployeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receiveBy           String        @db.NVarChar(100)
  conditionAfter      String        @db.NVarChar(50)
  missingAccessories  String?       @db.NVarChar(Max)
  damageNote          String?       @db.NVarChar(Max)
  photoAfter          String?       @db.NVarChar(500)
  nextStatus          String        @db.NVarChar(50) // Ready, Repair, Disposal
  nextLocationId      String        @db.NVarChar(100)
  remark              String?       @db.NVarChar(Max)
  createdAt           DateTime      @default(now())

  @@index([documentNo])
  @@map("asset_checkins")
}

model AssetMovement {
  id            String   @id @default(uuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  movementType  String   @db.NVarChar(50) // checkout, checkin, transfer, location_change, custodian_change, status_change, condition_change, department_change, audit_correction
  fromValue     String?  @db.NVarChar(500)
  toValue       String?  @db.NVarChar(500)
  reason        String?  @db.NVarChar(500)
  referenceType String?  @db.NVarChar(50) // checkout, checkin, transfer, audit_finding
  referenceId   String?  @db.NVarChar(100)
  performedBy   String   @db.NVarChar(100)
  performedAt   DateTime @default(now())
  remark        String?  @db.NVarChar(Max)

  @@index([assetId, performedAt], map: "IX_asset_movements_assetId_performedAt")
  @@index([referenceType, referenceId], map: "IX_asset_movements_referenceType_referenceId")
  @@map("asset_movements")
}

// ============================================================
// Asset Audit
// ============================================================

model AuditRound {
  id                String          @id @default(uuid())
  auditNo           String          @unique @db.NVarChar(50)
  name              String          @db.NVarChar(200)
  auditYear         Int
  scopeCompanyId    String?
  scopeCompany      Company?        @relation(fields: [scopeCompanyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeBranchId     String?
  scopeBranch       Branch?         @relation(fields: [scopeBranchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeDepartmentId String?
  scopeDepartment   Department?     @relation(fields: [scopeDepartmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeLocationId   String?
  scopeLocation     Location?       @relation(fields: [scopeLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeCategoryId   String?
  scopeCategory     AssetCategory?  @relation(fields: [scopeCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeCustodianId  String?
  scopeCustodian    Employee?       @relation(fields: [scopeCustodianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeStatusId     String?
  scopeStatus       AssetStatus?    @relation(fields: [scopeStatusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeConditionId  String?
  scopeCondition    AssetCondition? @relation(fields: [scopeConditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  startDate         DateTime
  endDate           DateTime
  status            String          @default("draft") @db.NVarChar(20)
  createdBy         String          @db.NVarChar(100)
  updatedBy         String?         @db.NVarChar(100)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  isActive          Boolean         @default(true)

  items       AuditItem[]
  findings    AuditFinding[]
  scanHistory AuditScanHistory[]

  @@index([isActive, status], map: "IX_audit_rounds_isActive_status")
  @@index([startDate, endDate], map: "IX_audit_rounds_startDate_endDate")
  @@map("audit_rounds")
}

model AuditItem {
  id                   String     @id @default(uuid())
  auditRoundId         String
  auditRound           AuditRound @relation(fields: [auditRoundId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetId              String
  asset                Asset      @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expectedCompanyId    String
  expectedBranchId     String
  expectedDepartmentId String?
  expectedLocationId   String
  expectedCustodianId  String?
  expectedConditionId  String?
  auditStatus          String     @default("pending") @db.NVarChar(30)
  auditResult          String?    @db.NVarChar(50)
  actualDepartmentId   String?
  actualLocationId     String?
  actualCustodianId    String?
  actualConditionId    String?
  findingRequired      Boolean    @default(false)
  reconcileStatus      String?    @db.NVarChar(30)
  scannedAt            DateTime?
  scannedBy            String?    @db.NVarChar(100)
  lastScanAt           DateTime?
  scanCount            Int        @default(0)
  photoEvidence        String?    @db.NVarChar(500)
  remark               String?    @db.NVarChar(Max)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  findings    AuditFinding[]
  scanHistory AuditScanHistory[]

  @@unique([auditRoundId, assetId])
  @@index([auditRoundId, auditStatus], map: "IX_audit_items_auditRoundId_auditStatus")
  @@index([assetId], map: "IX_audit_items_assetId")
  @@index([lastScanAt], map: "IX_audit_items_lastScanAt")
  @@map("audit_items")
}

model AuditFinding {
  id            String     @id @default(uuid())
  auditRoundId  String
  auditRound    AuditRound @relation(fields: [auditRoundId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditItemId   String
  auditItem     AuditItem  @relation(fields: [auditItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetId       String?
  asset         Asset?     @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  findingType   String     @db.NVarChar(50)
  expectedValue String?    @db.NVarChar(Max)
  actualValue   String?    @db.NVarChar(Max)
  evidenceFile  String?    @db.NVarChar(500)
  remark        String?    @db.NVarChar(Max)
  reportedBy    String     @db.NVarChar(100)
  reportedAt    DateTime   @default(now())
  reviewStatus  String     @default("pending") @db.NVarChar(30)
  reviewedBy    String?    @db.NVarChar(100)
  reviewedAt    DateTime?
  reviewRemark  String?    @db.NVarChar(Max)
  actionTaken   String?    @db.NVarChar(100)
  actionPlan    String?    @db.NVarChar(Max)
  actionOwnerId String?
  actionOwner   Employee?  @relation("AuditFindingActionOwner", fields: [actionOwnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actionDueDate DateTime?
  actionStatus  String     @default("not_required") @db.NVarChar(30)
  closedAt      DateTime?
  closureRemark String?    @db.NVarChar(Max)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([reviewStatus, actionStatus, actionDueDate], map: "IX_audit_findings_reviewStatus_actionStatus_actionDueDate")
  @@index([auditRoundId, reviewStatus], map: "IX_audit_findings_auditRoundId_reviewStatus")
  @@index([assetId], map: "IX_audit_findings_assetId")
  @@index([actionOwnerId], map: "IX_audit_findings_actionOwnerId")
  @@map("audit_findings")
}

model AuditScanHistory {
  id             String     @id @default(uuid())
  auditRoundId   String
  auditRound     AuditRound @relation(fields: [auditRoundId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditItemId    String?
  auditItem      AuditItem? @relation(fields: [auditItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetId        String
  asset          Asset      @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scannedBy      String     @db.NVarChar(100)
  scannedAt      DateTime   @default(now())
  scanLocationId String?
  scanLatitude   Decimal?   @db.Decimal(10, 7)
  scanLongitude  Decimal?   @db.Decimal(10, 7)
  scanSource     String     @default("manual") @db.NVarChar(30)
  rawPayload     String?    @db.NVarChar(Max)
  remark         String?    @db.NVarChar(Max)

  @@index([auditRoundId, scannedAt], map: "IX_audit_scan_history_auditRoundId_scannedAt")
  @@index([assetId, scannedAt], map: "IX_audit_scan_history_assetId_scannedAt")
  @@index([auditItemId], map: "IX_audit_scan_history_auditItemId")
  @@map("audit_scan_history")
}

// ============================================================
// Maintenance / Repair
// ============================================================

model MaintenancePlan {
  id              String    @id @default(uuid())
  planNo          String    @unique @db.NVarChar(50)
  assetId         String
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title           String    @db.NVarChar(200)
  frequency       String    @default("monthly") @db.NVarChar(30)
  intervalDays    Int       @default(30)
  nextDueDate     DateTime
  lastGeneratedAt DateTime?
  assignedToId    String?
  assignedTo      Employee? @relation("MaintenancePlanAssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendorId        String?
  vendor          Supplier? @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes           String?   @db.NVarChar(Max)
  createdBy       String    @db.NVarChar(100)
  updatedBy       String?   @db.NVarChar(100)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isActive        Boolean   @default(true)

  @@index([isActive, nextDueDate], map: "IX_maintenance_plans_isActive_nextDueDate")
  @@index([assetId], map: "IX_maintenance_plans_assetId")
  @@index([assignedToId], map: "IX_maintenance_plans_assignedToId")
  @@map("maintenance_plans")
}

model MaintenanceTicket {
  id            String    @id @default(uuid())
  repairNo      String    @unique @db.NVarChar(50)
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  problem       String    @db.NVarChar(Max)
  reportedById  String
  reportedBy    Employee  @relation("MaintenanceReportedBy", fields: [reportedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportedDate  DateTime  @default(now())
  assignedToId  String?
  assignedTo    Employee? @relation("MaintenanceAssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dueDate       DateTime?
  repairType    String    @db.NVarChar(30)
  vendorId      String?
  vendor        Supplier? @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  repairStatus  String    @default("open") @db.NVarChar(30)
  laborCost     Decimal?  @db.Decimal(18, 2)
  partsCost     Decimal?  @db.Decimal(18, 2)
  repairCost    Decimal?  @db.Decimal(18, 2)
  quotationNo   String?   @db.NVarChar(100)
  invoiceNo     String?   @db.NVarChar(100)
  warrantyClaim Boolean   @default(false)
  rootCause     String?   @db.NVarChar(Max)
  resolution    String?   @db.NVarChar(Max)
  returnDate    DateTime?
  inspectedById String?
  inspectedBy   Employee? @relation("MaintenanceInspectedBy", fields: [inspectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy     String    @db.NVarChar(100)
  updatedBy     String?   @db.NVarChar(100)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isActive      Boolean   @default(true)

  @@index([isActive, repairStatus, dueDate], map: "IX_maintenance_tickets_isActive_repairStatus_dueDate")
  @@index([assetId, reportedDate], map: "IX_maintenance_tickets_assetId_reportedDate")
  @@index([assignedToId], map: "IX_maintenance_tickets_assignedToId")
  @@index([reportedById], map: "IX_maintenance_tickets_reportedById")
  @@map("maintenance_tickets")
}

model DisposalRequest {
  id                 String    @id @default(uuid())
  disposalNo         String    @unique @db.NVarChar(50)
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  disposalType       String    @db.NVarChar(30)
  reason             String    @db.NVarChar(Max)
  requestedById      String
  requestedBy        Employee  @relation("DisposalRequestedBy", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestDate        DateTime  @default(now())
  approverId         String?
  approver           Employee? @relation("DisposalApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestStatus      String    @default("pending") @db.NVarChar(30)
  saleValue          Decimal?  @db.Decimal(18, 2)
  salvageValue       Decimal?  @db.Decimal(18, 2)
  approvalRemark     String?   @db.NVarChar(Max)
  approvedAt         DateTime?
  sourceType         String?   @db.NVarChar(50)
  sourceId           String?   @db.NVarChar(100)
  executionDate      DateTime?
  executedById       String?
  executedBy         Employee? @relation("DisposalExecutedBy", fields: [executedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipientName      String?   @db.NVarChar(200)
  documentNo         String?   @db.NVarChar(100)
  actualSaleValue    Decimal?  @db.Decimal(18, 2)
  actualSalvageValue Decimal?  @db.Decimal(18, 2)
  executionRemark    String?   @db.NVarChar(Max)
  completedAt        DateTime?
  createdBy          String    @db.NVarChar(100)
  updatedBy          String?   @db.NVarChar(100)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isActive           Boolean   @default(true)

  @@index([isActive, requestStatus, requestDate], map: "IX_disposal_requests_isActive_requestStatus_requestDate")
  @@index([assetId], map: "IX_disposal_requests_assetId")
  @@index([requestedById], map: "IX_disposal_requests_requestedById")
  @@map("disposal_requests")
}

// ============================================================
// Supplier
// ============================================================

model Supplier {
  id            String   @id @default(uuid())
  code          String   @unique @db.NVarChar(20)
  name          String   @db.NVarChar(200)
  contactPerson String?  @db.NVarChar(200)
  phone         String?  @db.NVarChar(50)
  email         String?  @db.NVarChar(200)
  address       String?  @db.NVarChar(500)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?  @db.NVarChar(100)
  updatedBy     String?  @db.NVarChar(100)

  assets             Asset[]
  maintenancePlans   MaintenancePlan[]
  maintenanceTickets MaintenanceTicket[]
  purchaseDocuments  PurchaseDocument[]

  @@map("suppliers")
}

// ============================================================
// File Attachments
// ============================================================

model Attachment {
  id           String   @id @default(uuid())
  assetId      String?
  asset        Asset?   @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  module       String   @db.NVarChar(50) // asset, checkout, checkin, transfer, repair, audit
  referenceId  String   @db.NVarChar(100) // ID of the parent record
  fileName     String   @db.NVarChar(500)
  originalName String   @db.NVarChar(500)
  fileType     String   @db.NVarChar(50)
  fileSize     Int
  filePath     String   @db.NVarChar(1000)
  uploadedBy   String   @db.NVarChar(100)
  uploadedAt   DateTime @default(now())
  isActive     Boolean  @default(true)

  @@index([assetId, isActive, uploadedAt], map: "IX_attachments_assetId_isActive_uploadedAt")
  @@index([module, referenceId, isActive, uploadedAt], map: "IX_attachments_module_referenceId_isActive_uploadedAt")
  @@map("attachments")
}

// ============================================================
// Authentication & Authorization
// ============================================================

model User {
  id           String    @id @default(uuid())
  username     String    @unique @db.NVarChar(100)
  passwordHash String    @db.NVarChar(500)
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  displayName  String    @db.NVarChar(200)
  email        String?   @db.NVarChar(200)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userRoles  UserRole[]
  systemLogs SystemLog[]

  @@map("users")
}

model Role {
  id            String   @id @default(uuid())
  name          String   @unique @db.NVarChar(50)
  displayName   String   @db.NVarChar(200)
  displayNameTh String?  @db.NVarChar(200)
  description   String?  @db.NVarChar(500)
  isSystem      Boolean  @default(false) // System roles cannot be deleted
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String  @db.NVarChar(50) // asset, company, branch, audit, report, etc.
  action      String  @db.NVarChar(50) // view, create, edit, delete, export, approve
  description String? @db.NVarChar(200)

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// System
// ============================================================

model SystemLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action    String   @db.NVarChar(50) // create, update, delete, login, logout, checkout, checkin, etc.
  module    String   @db.NVarChar(50) // asset, company, branch, etc.
  recordId  String?  @db.NVarChar(100)
  oldValue  String?  @db.NVarChar(Max)
  newValue  String?  @db.NVarChar(Max)
  ipAddress String?  @db.NVarChar(50)
  userAgent String?  @db.NVarChar(500)
  remark    String?  @db.NVarChar(500)
  createdAt DateTime @default(now())

  @@index([createdAt], map: "IX_system_logs_createdAt")
  @@index([module, action, createdAt], map: "IX_system_logs_module_action_createdAt")
  @@index([recordId], map: "IX_system_logs_recordId")
  @@index([userId, createdAt], map: "IX_system_logs_userId_createdAt")
  @@map("system_logs")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.NVarChar(100)
  value       String   @db.NVarChar(Max)
  description String?  @db.NVarChar(500)
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.NVarChar(100)

  @@map("system_settings")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @db.NVarChar(100)
  title       String   @db.NVarChar(200)
  message     String   @db.NVarChar(Max)
  type        String   @db.NVarChar(50) // info, warning, danger, success
  module      String?  @db.NVarChar(50)
  referenceId String?  @db.NVarChar(100)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("notifications")
}

model NotificationUserState {
  id               String    @id @default(uuid())
  userId           String    @db.NVarChar(100)
  key              String    @db.NVarChar(100)
  isRead           Boolean   @default(false)
  lastCount        Int       @default(0)
  snoozedUntil     DateTime?
  assignedToUserId String?   @db.NVarChar(100)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@index([assignedToUserId])
  @@map("notification_user_states")
}
